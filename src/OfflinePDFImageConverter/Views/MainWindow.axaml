<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OfflinePDFImageConverter.Views.MainWindow"
        Title="OfflinePDFImageConverter"
        Width="1040"
        Height="720"
        MinWidth="860"
        MinHeight="620"
        DragDrop.AllowDrop="True">
  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.mode">
      <Setter Property="MinWidth" Value="150" />
      <Setter Property="MinHeight" Value="54" />
      <Setter Property="FontSize" Value="17" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="18,12" />
    </Style>
    <Style Selector="Button.mode.active">
      <Setter Property="Background" Value="#0F6CBD" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0F6CBD" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="16,10" />
    </Style>
    <Style Selector="Button.preview-toggle">
      <Setter Property="MinWidth" Value="86" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.preview-toggle.active">
      <Setter Property="Background" Value="#0F6CBD" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,6" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Background="#F6F7F9">
    <Border Grid.Row="0"
            Background="White"
            BorderBrush="#D9DDE5"
            BorderThickness="0,0,0,1"
            Padding="22,16">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock Text="OfflinePDFImageConverter"
                     FontSize="24"
                     FontWeight="SemiBold" />
          <TextBlock Text="PDFと画像の変換、PDFの結合・分割をインターネットなしで行います。"
                     Foreground="#5B6472"
                     Margin="0,4,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
          <Button x:Name="PdfModeButton"
                  Classes="mode active"
                  Content="PDF → 画像"
                  Click="OnPdfModeClick" />
          <Button x:Name="ImageModeButton"
                  Classes="mode"
                  Content="画像 → PDF"
                  Click="OnImageModeClick" />
          <Button x:Name="PdfToolsModeButton"
                  Classes="mode"
                  Content="PDF操作"
                  Click="OnPdfToolsModeClick" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="22">
      <Grid x:Name="PdfPanel" ColumnDefinitions="2*,*" IsVisible="True">
        <Border Background="White"
                BorderBrush="#D9DDE5"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
          <Grid RowDefinitions="Auto,180,Auto,Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel>
                <TextBlock Text="PDFファイル"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock Text="複数PDFを追加できます。ドラッグ＆ドロップにも対応しています。"
                           Foreground="#5B6472"
                           Margin="0,4,0,0" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="追加" Click="OnAddPdfFilesClick" />
                <Button Content="削除" Click="OnRemovePdfFilesClick" />
                <Button Content="すべて削除" Click="OnClearPdfFilesClick" />
              </StackPanel>
            </Grid>

            <ListBox x:Name="PdfFilesList"
                     Grid.Row="1"
                     Margin="0,16,0,16"
                     SelectionMode="Multiple"
                     BorderBrush="#CCD2DC"
                     BorderThickness="1">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="8,6">
                    <TextBlock Text="{Binding DisplayName}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Folder}"
                               FontSize="12"
                               Foreground="#657184"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="2"
                       Text="ここにPDFファイルをドロップできます。"
                       Foreground="#657184" />
          </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="18,0,0,0"
                Background="White"
                BorderBrush="#D9DDE5"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
          <StackPanel Spacing="14">
            <TextBlock Text="出力設定"
                       FontSize="18"
                       FontWeight="SemiBold" />

            <StackPanel>
              <TextBlock Classes="label" Text="画像形式" />
              <ComboBox x:Name="PdfFormatCombo" SelectedIndex="0" MinWidth="180">
                <ComboBoxItem Content="PNG" />
                <ComboBoxItem Content="JPEG" />
              </ComboBox>
            </StackPanel>

            <StackPanel>
              <TextBlock Classes="label" Text="解像度" />
              <ComboBox x:Name="PdfDpiCombo" SelectedIndex="1" MinWidth="180">
                <ComboBoxItem Content="150 dpi" />
                <ComboBoxItem Content="200 dpi" />
                <ComboBoxItem Content="300 dpi" />
                <ComboBoxItem Content="400 dpi" />
                <ComboBoxItem Content="600 dpi" />
              </ComboBox>
            </StackPanel>

            <StackPanel>
              <TextBlock Classes="label" Text="出力先フォルダ" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="PdfOutputFolderTextBox" Watermark="保存先フォルダ" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="選択"
                        Click="OnSelectPdfOutputFolderClick" />
              </Grid>
            </StackPanel>

            <Button x:Name="StartPdfButton"
                    Classes="primary"
                    Content="変換開始"
                    HorizontalAlignment="Stretch"
                    Click="OnStartPdfConversionClick" />
          </StackPanel>
        </Border>
      </Grid>

      <Grid x:Name="ImagePanel" ColumnDefinitions="2*,*" IsVisible="False">
        <Border Background="White"
                BorderBrush="#D9DDE5"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
          <Grid RowDefinitions="Auto,120,Auto,Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel>
                <TextBlock Text="画像ファイル"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock Text="PDFに入れる順番で並べます。必要に応じて上下に移動できます。"
                           Foreground="#5B6472"
                           Margin="0,4,0,0" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="追加" Click="OnAddImageFilesClick" />
                <Button Content="削除" Click="OnRemoveImageFilesClick" />
                <Button Content="すべて削除" Click="OnClearImageFilesClick" />
              </StackPanel>
            </Grid>

            <ListBox x:Name="ImageFilesList"
                     Grid.Row="1"
                     Margin="0,16,0,16"
                     SelectionMode="Multiple"
                     BorderBrush="#CCD2DC"
                     BorderThickness="1">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="8,6">
                    <TextBlock Text="{Binding DisplayName}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Folder}"
                               FontSize="12"
                               Foreground="#657184"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
              <Button Content="上へ" Click="OnMoveImageUpClick" />
              <Button Content="下へ" Click="OnMoveImageDownClick" />
              <TextBlock Text="画像をドロップして追加できます。"
                         Foreground="#657184"
                         VerticalAlignment="Center"
                         Margin="8,0,0,0" />
            </StackPanel>
          </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="18,0,0,0"
                Background="White"
                BorderBrush="#D9DDE5"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
          <StackPanel Spacing="14">
            <TextBlock Text="PDF設定"
                       FontSize="18"
                       FontWeight="SemiBold" />

            <StackPanel>
              <TextBlock Classes="label" Text="ページサイズ" />
              <ComboBox x:Name="ImagePageModeCombo" SelectedIndex="0" MinWidth="180">
                <ComboBoxItem Content="A4縦" />
                <ComboBoxItem Content="A4横" />
                <ComboBoxItem Content="画像サイズに合わせる" />
              </ComboBox>
            </StackPanel>

            <CheckBox x:Name="ImageMarginCheckBox"
                      Content="余白あり"
                      IsChecked="True" />

            <StackPanel>
              <TextBlock Classes="label" Text="出力PDF" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="ImageOutputPdfTextBox" Watermark="保存先とPDF名" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="選択"
                        Click="OnSelectImageOutputPdfClick" />
              </Grid>
            </StackPanel>

            <Button x:Name="StartImageButton"
                    Classes="primary"
                    Content="変換開始"
                    HorizontalAlignment="Stretch"
                    Click="OnStartImageConversionClick" />
          </StackPanel>
        </Border>
      </Grid>

      <Grid x:Name="PdfToolsPanel" ColumnDefinitions="2*,*" IsVisible="False">
        <Border Background="White"
                BorderBrush="#D9DDE5"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
          <Grid RowDefinitions="Auto,120,Auto,Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel>
                <TextBlock Text="PDFファイル"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock Text="結合する順番で並べます。分割やページ削除にも使います。"
                           Foreground="#5B6472"
                           Margin="0,4,0,0" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="追加" Click="OnAddPdfFilesClick" />
                <Button Content="削除" Click="OnRemovePdfFilesClick" />
                <Button Content="すべて削除" Click="OnClearPdfFilesClick" />
              </StackPanel>
            </Grid>

            <ListBox x:Name="PdfToolFilesList"
                     Grid.Row="1"
                     Margin="0,16,0,16"
                     SelectionMode="Multiple"
                     BorderBrush="#CCD2DC"
                     BorderThickness="1">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="8,6">
                    <TextBlock Text="{Binding DisplayName}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Folder}"
                               FontSize="12"
                               Foreground="#657184"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
              <Button Content="上へ" Click="OnMovePdfUpClick" />
              <Button Content="下へ" Click="OnMovePdfDownClick" />
              <TextBlock Text="PDFをドロップして追加できます。"
                         Foreground="#657184"
                         VerticalAlignment="Center"
                         Margin="8,0,0,0" />
            </StackPanel>

            <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,18,0,8">
              <StackPanel>
                <TextBlock Text="ページプレビュー"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="PdfPreviewHelpText"
                           Text="PDFを追加すると、ページの見た目を確認できます。"
                           Foreground="#657184"
                           FontSize="12"
                           Margin="0,3,0,0" />
              </StackPanel>
              <Button x:Name="PdfPreviewIconButton"
                      Grid.Column="1"
                      Classes="preview-toggle active"
                      Content="アイコン"
                      VerticalAlignment="Bottom"
                      Click="OnPdfPreviewIconClick" />
              <Button x:Name="PdfPreviewListButton"
                      Grid.Column="2"
                      Classes="preview-toggle"
                      Content="リスト"
                      Margin="8,0,0,0"
                      VerticalAlignment="Bottom"
                      Click="OnPdfPreviewListClick" />
              <Button Grid.Column="3"
                      Content="更新"
                      Margin="8,0,0,0"
                      VerticalAlignment="Bottom"
                      Click="OnRefreshPdfPreviewClick" />
            </Grid>

            <Border Grid.Row="4"
                    BorderBrush="#CCD2DC"
                    BorderThickness="1"
                    ClipToBounds="True">
              <Grid>
                <ScrollViewer x:Name="PdfPagePreviewThumbnailScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <ItemsControl x:Name="PdfPagePreviewThumbnailItems">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Width="150"
                                MinHeight="210"
                                Background="#FAFBFC"
                                BorderBrush="#D9DDE5"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="8"
                                Padding="8">
                          <StackPanel Spacing="6">
                            <Image Source="{Binding Thumbnail}"
                                   Width="126"
                                   Height="150"
                                   Stretch="Uniform" />
                            <TextBlock Text="{Binding PageLabel}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Title}"
                                       FontSize="11"
                                       Foreground="#657184"
                                       TextTrimming="CharacterEllipsis" />
                            <CheckBox Content="削除"
                                      IsVisible="{Binding IsDeleteSelectionVisible}"
                                      IsChecked="{Binding IsMarkedForDelete}"
                                      Checked="OnPdfPreviewDeleteSelectionChanged"
                                      Unchecked="OnPdfPreviewDeleteSelectionChanged" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>

                <ScrollViewer x:Name="PdfPagePreviewListScroll"
                              IsVisible="False"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <ItemsControl x:Name="PdfPagePreviewListItems">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              Margin="10,8">
                          <TextBlock Grid.Column="0"
                                     Text="{Binding PageLabel}"
                                     Width="72"
                                     FontWeight="SemiBold"
                                     VerticalAlignment="Center" />
                          <StackPanel Grid.Column="1"
                                      VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding PdfPath}"
                                       FontSize="11"
                                       Foreground="#657184"
                                       TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                          <CheckBox Grid.Column="2"
                                    Content="削除"
                                    IsVisible="{Binding IsDeleteSelectionVisible}"
                                    IsChecked="{Binding IsMarkedForDelete}"
                                    VerticalAlignment="Center"
                                    Checked="OnPdfPreviewDeleteSelectionChanged"
                                    Unchecked="OnPdfPreviewDeleteSelectionChanged" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="18,0,0,0"
                Background="White"
                BorderBrush="#D9DDE5"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
          <StackPanel Spacing="14">
            <TextBlock Text="PDF操作"
                       FontSize="18"
                       FontWeight="SemiBold" />

            <StackPanel>
              <TextBlock Classes="label" Text="操作" />
              <ComboBox x:Name="PdfToolOperationCombo"
                        SelectedIndex="0"
                        MinWidth="220"
                        SelectionChanged="OnPdfToolOperationChanged">
                <ComboBoxItem Content="複数PDFを結合" />
                <ComboBoxItem Content="1ページずつ分割" />
                <ComboBoxItem Content="選択ページを削除" />
              </ComboBox>
            </StackPanel>

            <StackPanel x:Name="PdfToolOutputPdfPanel">
              <TextBlock x:Name="PdfToolOutputPdfLabel"
                         Classes="label"
                         Text="出力PDF" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="PdfToolOutputPdfTextBox" Watermark="保存先とPDF名" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="選択"
                        Click="OnSelectPdfToolOutputPdfClick" />
              </Grid>
            </StackPanel>

            <StackPanel x:Name="PdfToolOutputFolderPanel" IsVisible="False">
              <TextBlock Classes="label" Text="出力先フォルダ" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="PdfToolOutputFolderTextBox" Watermark="保存先フォルダ" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="選択"
                        Click="OnSelectPdfToolOutputFolderClick" />
              </Grid>
            </StackPanel>

            <StackPanel x:Name="PdfDeletePagesPanel" IsVisible="False">
              <TextBlock Classes="label" Text="削除するページ" />
              <TextBox x:Name="PdfDeletePagesTextBox" Watermark="例: 1,3,5-7" />
              <TextBlock Text="ページ番号はPDFの先頭を1ページ目として指定します。"
                         Foreground="#657184"
                         FontSize="12"
                         Margin="0,6,0,0" />
            </StackPanel>

            <Button x:Name="StartPdfToolButton"
                    Classes="primary"
                    Content="実行"
                    HorizontalAlignment="Stretch"
                    Click="OnStartPdfToolClick" />
          </StackPanel>
        </Border>
      </Grid>
    </Grid>

    <Border Grid.Row="2"
            Background="White"
            BorderBrush="#D9DDE5"
            BorderThickness="0,1,0,0"
            Padding="22,14">
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
        <ProgressBar x:Name="MainProgressBar"
                     Minimum="0"
                     Maximum="100"
                     Height="14" />
        <TextBlock x:Name="StatusText"
                   Grid.Row="1"
                   Text="PDFファイルを選ぶか、画像 → PDFに切り替えて画像を選んでください。"
                   Foreground="#4E5968"
                   Margin="0,8,0,0" />
        <Button x:Name="CancelButton"
                Grid.Column="1"
                Grid.RowSpan="2"
                Content="中止"
                IsEnabled="False"
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Click="OnCancelClick" />
      </Grid>
    </Border>
  </Grid>
</Window>
